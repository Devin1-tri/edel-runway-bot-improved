# ─────────────────────────────────────────────────
#  Edel Runway Bot — Configuration
# ─────────────────────────────────────────────────

# Voting Strategy: random | smart | first | second
VOTE_STRATEGY=smart

# Dynamic Scheduling
VOTE_INTERVAL_MINUTES=60
VOTE_BUFFER_MINUTES=2
RETRY_INTERVAL_MINUTES=5

# Retry
MAX_RETRIES=3
RETRY_DELAY=5000

# Telegram Bot (Interactive Control)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Session Keep-Alive (prevent idle timeout)
KEEPALIVE_ENABLED=true
KEEPALIVE_INTERVAL_MINUTES=30

# Log Level: error | warn | info | debug
LOG_LEVEL=info

# Base URL (default: https://runway.edel.finance)
BASE_URL=https://runway.edel.finance
