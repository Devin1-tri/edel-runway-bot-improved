# ==============================================================================
# Edel Runway Bot (Improved v3.0) Configuration
# Copy this file to .env and edit as needed
# ==============================================================================

# Voting Strategy: "random" | "smart" | "first" | "second"
#   random = pilih acak dari 2 asset
#   smart  = analisa data di halaman, pilih yang lebih populer/momentum
#   first  = selalu pilih asset pertama (kiri)
#   second = selalu pilih asset kedua (kanan)
VOTE_STRATEGY=smart

# Dynamic Scheduling
# Interval antar vote setelah sukses (menit)
VOTE_INTERVAL_MINUTES=60
# Buffer tambahan agar EDELx sempat unlock (menit)
VOTE_BUFFER_MINUTES=5
# Retry interval jika belum siap / gagal (menit)
RETRY_INTERVAL_MINUTES=5

# Browser Settings (Deprecated, kept for compatibility if needed)
HEADLESS=true
SLOW_MO=500
PAGE_TIMEOUT=30000

# Retry Settings
MAX_RETRIES=3
RETRY_DELAY=5000

# Screenshot (Deprecated in pure HTTP, kept for compatibility)
SAVE_SCREENSHOTS=false

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Runway Desk URL
BASE_URL=https://runway.edel.finance

# ==============================================================================
# Telegram Bot Notifications & Two-Way Interactive Control (REVOLUSIONER!)
# ==============================================================================
# Dengan mengaktifkan ini, kamu bisa memperbarui cookie/JWT token yang expired
# langsung lewat chat Telegram! Gak perlu SSH, ganti screen, atau matiin bot!
# 
# 1. Buat bot baru di Telegram: cari @BotFather di Telegram lalu kirim /newbot
# 2. Copy token yang diberikan ke TELEGRAM_BOT_TOKEN di bawah ini
# 3. Kirim pesan apa saja ke bot kamu (misal: "hallo")
# 4. Buka di browser: https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Cari "chat":{"id": 123456789 } → copy angka ID tersebut ke TELEGRAM_CHAT_ID di bawah
# ==============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
